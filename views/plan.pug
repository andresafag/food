doctype html
html(lang="en")
  head
    title= "Meal Planner"
    link(rel="stylesheet", href="./styles.css", type="text/css")
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin='')
    link(href='https://fonts.googleapis.com/css2?family=Fredericka+the+Great&family=Fugaz+One&family=Grape+Nuts&family=Pangolin&display=swap' rel='stylesheet')
    script(src='https://kit.fontawesome.com/adf65eea78.js' crossorigin='anonymous')
    style.
      #planner_section {
        max-width: 860px;
        margin: 2.5rem auto;
        padding: 0 1.5rem 3rem;
      }

      #planner_section h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1.75rem;
        color: #1a1a1a;
        letter-spacing: -0.5px;
      }

      #planner-form {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      }

      .form-section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9ca3af;
        margin: 1.5rem 0 0.75rem;
      }

      .form-row {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        margin-bottom: 1rem;
      }

      .form-row label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #374151;
      }

      .form-row input[type="text"],
      .form-row input[type="number"],
      .form-row select {
        padding: 0.6rem 0.85rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 0.95rem;
        color: #111827;
        background: #f9fafb;
        transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
        outline: none;
        width: 100%;
        box-sizing: border-box;
      }

      .form-row input[type="text"]:focus,
      .form-row input[type="number"]:focus,
      .form-row select:focus {
        border-color: #f97316;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(249,115,22,0.12);
      }

      .form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem 1.25rem;
      }

      #generatePlan {
        width: 100%;
        padding: 0.95rem 1rem;
        background: #f97316;
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        border: none;
        border-radius: 9px;
        cursor: pointer;
        letter-spacing: 0.02em;
        transition: background 0.15s, transform 0.1s;
        margin-top: 1rem;
      }

      #generatePlan:hover {
        background: #ea6c0a;
      }

      #generatePlan:active {
        transform: scale(0.98);
      }

      .tooltiptext {
        display: block;
        color: #dc2626;
        font-size: 0.9rem;
        margin-top: 0.75rem;
        visibility: hidden;
      }

      #mealPlanContent {
        margin-top: 2rem;
      }

      .week-day-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9ca3af;
        margin: 1.75rem 0 0.75rem;
      }

      .week-day-label:first-child {
        margin-top: 0;
      }

      .week-nutrients {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 10px;
        padding: 0.85rem 1.25rem;
        margin-top: 0.5rem;
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .week-nutrients span {
        font-size: 0.82rem;
        color: #c2410c;
        font-weight: 600;
      }

      .week-nutrients span b {
        color: #7c2d12;
      }

      .meal-item-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
        transition: box-shadow 0.15s;
      }

      .meal-item-card:hover {
        box-shadow: 0 4px 14px rgba(0,0,0,0.09);
      }

      .meal-item-card img {
        width: 88px;
        height: 88px;
        object-fit: cover;
        border-radius: 8px;
        background: #f3f4f6;
        flex-shrink: 0;
      }

      .meal-item-card h2 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 0.3rem;
      }

      .meal-item-card p {
        margin: 0.2rem 0;
        font-size: 0.875rem;
        color: #6b7280;
      }

      .planMessage {
        font-size: 1rem;
        color: #4b5563;
      }

  body
    nav
      include components/nav.pug
    section(id="planner_section")
      h1 Meal Planner
      form(id="planner-form")
        p.form-section-label Planner Details
        .form-grid-2
          .form-row
            label(for="timeFrame") Time Frame
            select#timeFrame(name="timeFrame")
              option(value="day") Day
              option(value="week") Week
          .form-row
            label(for="targetCalories") Target Calories
            input(type="number", id="targetCalories", name="targetCalories", placeholder="2000", min="0")
        .form-grid-2
          .form-row
            label(for="diet") Diet
            input(type="text", id="diet", name="diet", placeholder="vegetarian")
          .form-row
            label(for="exclude") Exclude
            input(type="text", id="exclude", name="exclude", placeholder="shellfish, olives")
        span.tooltiptext
        button(type="submit", id="generatePlan") Generate Plan
      article
        div(id="mealPlanContent")
          p.planMessage Let's create your personalized meal plan!
    include components/footer
    script(src="./hamburgerMenu.js")
    script.
      const IMG_BASE = 'https://spoonacular.com/recipeImages/';
      const DAYS = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];

      let timeFrameInput   = document.querySelector('#timeFrame'),
          targetCaloriesInput = document.querySelector('#targetCalories'),
          dietInput        = document.querySelector('#diet'),
          excludeInput     = document.querySelector('#exclude'),
          mealPlanContent  = document.querySelector('#mealPlanContent'),
          generatePlanBtn  = document.querySelector('#generatePlan'),
          tooltipText      = document.querySelector('.tooltiptext');

      function mealCardHTML(meal) {
        const imgSrc = meal.image
          ? (meal.image.startsWith('http') ? meal.image : IMG_BASE + meal.image)
          : '';
        const imgTag = imgSrc ? `<img src="${imgSrc}" alt="${meal.title}" class="recipeimg" />` : '';
        return `
          <div class="mainfoodcontainer">
            <div class="foodContentboxTittle">
              <div class="title">${meal.title}</div>
            </div>
            <div class="adittionalContent">
              <p>Ready in: ${meal.readyInMinutes} minutes</p>
              <p>Servings: ${meal.servings}</p>
            </div>
            <div class="foodContent">
              ${imgTag}
              ${meal.sourceUrl ? `<p><a href="${meal.sourceUrl}" target="_blank">View full recipe</a></p>` : ''}
            </div>
          </div>
        `;
      }

      function renderDay(meals) {
        return meals.map(mealCardHTML).join('');
      }

      function renderWeek(week) {
        return DAYS.map(day => {
          if (!week[day]) return '';
          const { meals, nutrients } = week[day];
          const nutrientBar = nutrients ? `
            <div class="week-nutrients">
              <span><b>Calories:</b> ${Math.round(nutrients.calories)} kcal</span>
              <span><b>Protein:</b> ${Math.round(nutrients.protein)}g</span>
              <span><b>Fat:</b> ${Math.round(nutrients.fat)}g</span>
              <span><b>Carbs:</b> ${Math.round(nutrients.carbohydrates)}g</span>
            </div>
          ` : '';
          return `
            <p class="week-day-label">${day}</p>
            ${nutrientBar}
            ${meals.map(mealCardHTML).join('')}
          `;
        }).join('');
      }

      generatePlanBtn.addEventListener('click', function(e) {
        e.preventDefault();

        if (!targetCaloriesInput.value) {
          tooltipText.innerHTML = "Please enter a target calorie count";
          tooltipText.style.visibility = "visible";
          setTimeout(() => tooltipText.style.visibility = "hidden", 3000);
          return;
        }

        let params = {
          timeFrame: timeFrameInput.value,
          targetCalories: targetCaloriesInput.value
        };
        if (dietInput.value)    params.diet    = dietInput.value;
        if (excludeInput.value) params.exclude = excludeInput.value;

        let url = `https://api.spoonacular.com/mealplanner/generate?${new URLSearchParams(params)}&apiKey=#{apiKey}`;

        mealPlanContent.innerHTML = '<p class="planMessage">Generating your meal plan…</p>';

        fetch(url)
          .then(r => r.json())
          .then(data => {
            // day response → { meals: [...], nutrients: {} }
            if (data.meals) {
              mealPlanContent.innerHTML = renderDay(data.meals);
            }
            // week response → { week: { monday: { meals: [...] }, ... } }
            else if (data.week) {
              mealPlanContent.innerHTML = renderWeek(data.week);
            }
            else {
              tooltipText.innerHTML = "Unexpected response from API";
              tooltipText.style.visibility = "visible";
              setTimeout(() => tooltipText.style.visibility = "hidden", 3000);
            }
          })
          .catch(err => {
            tooltipText.innerHTML = "Error: " + err.message;
            tooltipText.style.visibility = "visible";
          });
      });
