doctype html
html(lang="en")
  head
    title= "Meal Planner"
    link(rel="stylesheet", href="./styles.css", type="text/css")
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin='')
    link(href='https://fonts.googleapis.com/css2?family=Fredericka+the+Great&family=Fugaz+One&family=Grape+Nuts&family=Pangolin&display=swap' rel='stylesheet')
    script(src='https://kit.fontawesome.com/adf65eea78.js' crossorigin='anonymous')
  body
    nav
      include components/nav.pug
    section(id="planner_section")
      h1 Meal Planner
      form(id="planner-form")
        p.form-section-label Planner Details
        .form-grid-2
          .form-row
            label(for="timeFrame") Time Frame
            select#timeFrame(name="timeFrame")
              option(value="day") Day
              option(value="week") Week
          .form-row
            label(for="targetCalories") Target Calories
            input(type="number", id="targetCalories", name="targetCalories", placeholder="2000", min="0")
        .form-grid-2
          .form-row
            label(for="diet") Diet
            input(type="text", id="diet", name="diet", placeholder="vegetarian")
          .form-row
            label(for="exclude") Exclude
            input(type="text", id="exclude", name="exclude", placeholder="shellfish, olives")
        span.tooltiptext
        button(type="submit", id="generatePlan") Generate Plan
      article
        div(id="mealPlanContent")
          p.planMessage Let's create your personalized meal plan!
    include components/footer
    script(src="./hamburgerMenu.js")
    script.
      const IMG_BASE = 'https://spoonacular.com/recipeImages/';
      const DAYS = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];

      let timeFrameInput   = document.querySelector('#timeFrame'),
          targetCaloriesInput = document.querySelector('#targetCalories'),
          dietInput        = document.querySelector('#diet'),
          excludeInput     = document.querySelector('#exclude'),
          mealPlanContent  = document.querySelector('#mealPlanContent'),
          generatePlanBtn  = document.querySelector('#generatePlan'),
          tooltipText      = document.querySelector('.tooltiptext');

      function mealCardHTML(meal) {
        const imgSrc = meal.image
          ? (meal.image.startsWith('http') ? meal.image : IMG_BASE + meal.image)
          : '';
        const imgTag = imgSrc ? `<img src="${imgSrc}" alt="${meal.title}" />` : '';
        return `
          <div class="meal-item-card">
            ${imgTag}
            <div>
              <h2>${meal.title}</h2>
              <p>Ready in: ${meal.readyInMinutes} minutes</p>
              <p>Servings: ${meal.servings}</p>
            </div>
          </div>
        `;
      }

      function renderDay(dayData) {
        // If the object or meals array is missing, return an empty string
        if (!dayData || !dayData.meals) return '';

        const { meals, nutrients } = dayData;

        const nutrientBar = nutrients ? `
          <div class="week-nutrients">
            <span><b>Calories:</b> ${Math.round(nutrients.calories)} kcal</span>
            <span><b>Protein:</b> ${Math.round(nutrients.protein)}g</span>
            <span><b>Fat:</b> ${Math.round(nutrients.fat)}g</span>
            <span><b>Carbs:</b> ${Math.round(nutrients.carbohydrates)}g</span>
          </div>
        ` : '';

        return `
          ${nutrientBar}
          ${meals.map(mealCardHTML).join('')}
        `;
      }

      function renderWeek(week) {
        return DAYS.map(day => {
          if (!week[day]) return '';
          const { meals, nutrients } = week[day];
          const nutrientBar = nutrients ? `
            <div class="week-nutrients">
              <span><b>Calories:</b> ${Math.round(nutrients.calories)} kcal</span>
              <span><b>Protein:</b> ${Math.round(nutrients.protein)}g</span>
              <span><b>Fat:</b> ${Math.round(nutrients.fat)}g</span>
              <span><b>Carbs:</b> ${Math.round(nutrients.carbohydrates)}g</span>
            </div>
          ` : '';
          return `
            <p class="week-day-label">${day}</p>
            ${nutrientBar}
            ${meals.map(mealCardHTML).join('')}
          `;
        }).join('');
      }

      generatePlanBtn.addEventListener('click', function(e) {
        e.preventDefault();

        if (!targetCaloriesInput.value) {
          tooltipText.innerHTML = "Please enter a target calorie count";
          tooltipText.style.visibility = "visible";
          setTimeout(() => tooltipText.style.visibility = "hidden", 3000);
          return;
        }

        let params = {
          timeFrame: timeFrameInput.value,
          targetCalories: targetCaloriesInput.value
        };
        if (dietInput.value)    params.diet    = dietInput.value;
        if (excludeInput.value) params.exclude = excludeInput.value;

        let url = `https://api.spoonacular.com/mealplanner/generate?${new URLSearchParams(params)}&apiKey=#{apiKey}`;

        mealPlanContent.innerHTML = '<p class="planMessage">Generating your meal plan…</p>';

        fetch(url)
          .then(r => r.json())
          .then(data => {
            // day response → { meals: [...], nutrients: {} }
            console.log(data);
            if (data.meals) {
              mealPlanContent.innerHTML = renderDay(data);
            }
            // week response → { week: { monday: { meals: [...] }, ... } }
            else if (data.week) {
              mealPlanContent.innerHTML = renderWeek(data.week);
            }
            else {
              tooltipText.innerHTML = "Unexpected response from API";
              tooltipText.style.visibility = "visible";
              setTimeout(() => tooltipText.style.visibility = "hidden", 3000);
            }
          })
          .catch(err => {
            tooltipText.innerHTML = "Error: " + err.message;
            tooltipText.style.visibility = "visible";
          });
      });
