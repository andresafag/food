doctype html
html(lang="en")
  head
    title= "Food"
    link(rel="stylesheet", href="./styles.css", type="text/css")
    link(rel='preconnect' href='https://fonts.googleapis.com')
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin='')
    link(href='https://fonts.googleapis.com/css2?family=Fredericka+the+Great&family=Fugaz+One&family=Grape+Nuts&family=Pangolin&display=swap' rel='stylesheet')
    script(src='https://kit.fontawesome.com/adf65eea78.js' crossorigin='anonymous')
    style.
      #send-info { text-align: center; }
      #send-info .food-title { margin-bottom: 1rem; }
      #send-info .food-title h2 { margin: 0; font-size: 1.8rem; font-family: 'Pangolin', cursive; color: #222; text-transform: uppercase; letter-spacing: 0.05em; }
  body  
    nav
      include components/nav.pug
    section(id="submit_section")
      div(id="form-section")
        div
          form
            div(id="send-info")
              div(class="food-title")
                h2 Favorite food or dish
              input(type="text", id="food", name="food")
              span.tooltiptext 
              input(type="submit", id="submit", value="Yummy")
              i.fa-solid.fa-utensils
      article 
        div(id="contentForFood")
          img(alt="welcomeimg", id="imge")
    include components/footer
script(src="./hamburgerMenu.js")
script.
  window.onload = randomp;
  var pic_rand = ["./images/merengue.jpg", "./images/pasta.jpg", "./images/smoothie.jpg"];
  
  function randomp(){
    var randomNum = Math.floor(Math.random() * pic_rand.length);
    document.getElementById("imge").src = pic_rand[randomNum];
  }

  (function(){
    const foodInput = document.querySelector('#food'),
          contentForFood = document.querySelector('#contentForFood'),
          searchFood = document.querySelector('#submit'),
          tooltipText = document.querySelector('.tooltiptext');

    function nutrientFrom(respon, key){
      if(!respon || !respon.nutrition || !respon.nutrition.nutrients) return 0;
      const found = respon.nutrition.nutrients.find(n => n.name.toLowerCase().includes(key));
      return found ? Math.round(found.amount) : 0;
    }

    function mealCardHTML(respon){
      const imgSrc = respon.image || '';
      const calories = nutrientFrom(respon, 'calories');
      const protein = nutrientFrom(respon, 'protein');
      const fat = nutrientFrom(respon, 'fat');
      const carbs = nutrientFrom(respon, 'carbohydrates') || nutrientFrom(respon, 'carbs');
      const nutrientBar = (calories||protein||fat||carbs) ? `\n        <div class="week-nutrients">\n          <span><b>Calories:</b> ${calories} kcal</span>\n          <span><b>Protein:</b> ${protein}g</span>\n          <span><b>Fat:</b> ${fat}g</span>\n          <span><b>Carbs:</b> ${carbs}g</span>\n        </div>\n      ` : '';

      const imgTag = imgSrc ? `<img src="${imgSrc}" alt="${respon.title}" />` : '';

      const likes = respon.aggregateLikes || 0;
      const cheap = respon.cheap ? 'Yes' : 'No';
      const cookingMinutes = respon.cookingMinutes || respon.preparationMinutes || '';
      const credits = respon.creditsText || respon.sourceName || '';

      const diets = Array.isArray(respon.diets) ? respon.diets : [];
      const cuisines = Array.isArray(respon.cuisines) ? respon.cuisines : [];
      const dishTypes = Array.isArray(respon.dishTypes) ? respon.dishTypes : [];

      const tags = [...diets, ...cuisines, ...dishTypes].filter(Boolean);
      const tagsHtml = tags.length ? `<div class="tags">${tags.map(t => `<span>${t}</span>`).join('')}</div>` : '';

      const ingredients = Array.isArray(respon.extendedIngredients) ? respon.extendedIngredients.map(ing => {
        const text = ing.original || (ing.amount ? `${ing.amount} ${ing.unit || ''} ${ing.name}` : ing.name);
        return `<li>${text}</li>`;
      }).join('') : '';

      let instructionsHtml = '';
      if(Array.isArray(respon.analyzedInstructions) && respon.analyzedInstructions.length){
        const emojis = ['🍝','🍕','🥗','🍜','🥘','🍣','🌮','🍛','🍲','🥟'];
        instructionsHtml = '<ul>' + respon.analyzedInstructions.map(instr => instr.steps.map(s => {
          const emoji = emojis[Math.floor(Math.random()*emojis.length)];
          return `<li>${emoji} ${s.step}</li>`;
        }).join('')).join('') + '</ul>';
      } else if(respon.instructions){
        // If only plain instructions string is available, strip numeric prefixes like "1. " and show as paragraphs
        const stripped = respon.instructions.replace(/\d+\.\s*/g, '');
        instructionsHtml = `<div>${stripped}</div>`;
      }

      const summaryHtml = respon.summary ? `<div class="credits">${respon.summary}</div>` : '';

      return `\n        ${nutrientBar}\n        <div class="meal-item-card">\n          ${imgTag}\n          <div>\n            <h2>${respon.title || ''}</h2>\n            <div class="meta">\n              <span>Ready in: ${respon.readyInMinutes || 'N/A'} min</span>\n              <span>Servings: ${respon.servings || 'N/A'}</span>\n              <span>Likes: ${likes}</span>\n              <span>Cheap: ${cheap}</span>\n            </div>\n            ${tagsHtml}\n            <div class="credits">Source: ${credits}</div>\n            ${ingredients ? `<h4>Ingredients</h4><ul class="ingredients-list">${ingredients}</ul>` : ''}\n            ${instructionsHtml ? `<h4>Instructions</h4><div class="instruction-steps">${instructionsHtml}</div>` : ''}\n            ${summaryHtml}\n          </div>\n        </div>\n      `;
    }

    async function searchHandler(e){
      e.preventDefault();
      if(!foodInput.value || !foodInput.value.trim()){
        tooltipText.innerHTML = "You didnt enter anything";
        tooltipText.style.visibility = 'visible';
        setTimeout(()=> tooltipText.style.visibility = 'hidden', 3000);
        return;
      }

      contentForFood.innerHTML = '<p class="planMessage">Searching…</p>';

      try{
        const q = encodeURIComponent(foodInput.value.trim());
        const searchRes = await fetch(`https://api.spoonacular.com/recipes/complexSearch?query=${q}&number=10&apiKey=#{apiKey}`);
        const searchJson = await searchRes.json();
        console.log('searchJson', searchJson);
        if(!searchJson.results || searchJson.results.length === 0){
          tooltipText.innerHTML = "No such food information in the database";
          tooltipText.style.visibility = 'visible';
          setTimeout(()=>{ tooltipText.style.visibility = 'hidden'; randomp(); }, 3000);
          contentForFood.innerHTML = '';
          return;
        }

        const ids = searchJson.results.map(r => r.id);
        const details = await Promise.all(ids.map(id => fetch(`https://api.spoonacular.com/recipes/${id}/information?apiKey=#{apiKey}`).then(r=>r.json())));
        console.log('details', details);
        contentForFood.innerHTML = details.map(d => mealCardHTML(d)).join('');
      }catch(err){
        tooltipText.innerHTML = "Error: " + err.message;
        tooltipText.style.visibility = 'visible';
      }
    }

    searchFood.addEventListener('click', searchHandler);
  })();
